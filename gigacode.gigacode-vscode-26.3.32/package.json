{
	"name": "gigacode-vscode",
	"displayName": "%gigacode.displayName%",
	"publisher": "GigaCode",
	"engines": {
		"vscode": "^1.82.0",
		"node": "^20.12.2"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"version": "26.3.32",
	"type": "commonjs",
	"main": "./dist/extension.js",
	"l10n": "./l10n",
	"scripts": {
		"vitest:mcpregistry": "vitest run src/modules/chat/mcp/__tests__/McpRegistry.spec.ts",
		"compile": "npm run check-types && node esbuild.js",
		"check-types": "tsc --noEmit",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:esbuild:onprem": "cross-env PLUGIN_TYPE=onprem node esbuild.js --watch",
		"watch:esbuild:enterprise": "cross-env PLUGIN_TYPE=enterprise node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"build": "npm run eslint && npm run check-types && node esbuild.js --production",
		"vsce": "vsce package --no-git-tag-version --no-update-package-json",
		"eslint": "eslint",
		"test": "mocha",
		"test:all": "mocha",
		"test:coverage": "c8 --reporter=text --reporter=lcov mocha",
		"test:watch": "mocha --watch",
		"generate-types": "node scripts/generateTypes.mjs",
		"package": "node scripts/package.mjs",
		"l10n": "npx @vscode/l10n-dev export --outDir ./l10n ./src",
		"generate-readme:dev": "node scripts/generateReadme.mjs dev"
	},
	"keywords": [],
	"license": "ISC",
	"description": "%gigacode.description%",
	"icon": "gigacode-icon.png",
	"contributes": {
		"commands": [
			{
				"command": "gigacode.openSettings",
				"title": "%gigacode.commands.openSettings%",
				"icon": "$(settings)",
				"category": "GigaCode"
			},
			{
				"command": "gigacode.checkUpdates",
				"title": "%gigacode.commands.checkUpdates%",
				"category": "GigaCode"
			},
			{
				"command": "gigacode.openChatHistory",
				"title": "%gigacode.commands.openChatHistory%",
				"icon": "$(history)",
				"category": "GigaCode"
			},
			{
				"command": "gigacode.newChat",
				"title": "%gigacode.commands.newChat%",
				"icon": "$(add)",
				"category": "GigaCode"
			},
			{
				"command": "gigacode.toggleCompletions",
				"title": "%gigacode.commands.toggleCompletions%",
				"category": "GigaCode"
			},
			{
				"command": "gigacode.openTerminal",
				"title": "Open GigaCode Terminal",
				"icon": "$(terminal)",
				"category": "GigaCode"
			}
		],
		"icons": {
			"gigacode-icon": {
				"description": "GigaCode icon",
				"default": {
					"fontPath": "gigacode.woff",
					"fontCharacter": "\\E900"
				}
			}
		},
		"menus": {
			"view/title": [],
			"commandPalette": [
				{
					"command": "gigacode.checkUpdates",
					"when": "gigacode.isReady"
				},
				{
					"command": "gigacode.openSettings",
					"when": "gigacode.isReady"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "gigacode",
					"title": "GigaCode",
					"icon": "gigacode-icon.png"
				}
			]
		},
		"views": {
			"gigacode": [
				{
					"type": "webview",
					"id": "gigacode.sidebar",
					"name": "GigaCode",
					"icon": "gigacode-icon.png"
				}
			]
		},
		"terminal": {
			"profiles": [
				{
					"id": "gigacode.terminal",
					"title": "GigaCode Terminal"
				}
			]
		},
		"keybindings": [
			{
				"command": "gigacode.toggleCompletions",
				"key": "ALT+\\",
				"mac": "OPT+\\"
			}
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.24.0",
		"@istanbuljs/nyc-config-typescript": "^1.0.2",
		"@stylistic/eslint-plugin": "^4.2.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/chai": "^5.2.3",
		"@types/expect": "24.3.2",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/lodash": "4.17.20",
		"@types/micromatch": "^4.0.10",
		"@types/minimatch": "^5.1.2",
		"@types/mocha": "10.0.10",
		"@types/mock-fs": "4.13.4",
		"@types/mock-require": "3.0.0",
		"@types/node": "20.19.31",
		"@types/prismjs": "1.26.5",
		"@types/proper-lockfile": "4.1.4",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@types/semver": "7.7.0",
		"@types/sinon": "^17.0.4",
		"@types/sinon-chai": "^4.0.0",
		"@types/vscode": "1.82.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/vsce": "^3.3.2",
		"c8": "^10.1.3",
		"chai": "^6.2.0",
		"esbuild": "^0.25.0",
		"esbuild-sass-plugin": "^3.3.1",
		"eslint": "^9.24.0",
		"json-schema-to-typescript": "15.0.4",
		"lodash": "^4.17.21",
		"mocha": "^11.1.0",
		"mocha-multi-reporters": "1.5.1",
		"mocha-sonarqube-reporter": "1.0.2",
		"mock-fs": "5.5.0",
		"mock-require": "3.0.3",
		"nyc": "^17.1.0",
		"sinon": "^20.0.0",
		"sinon-chai": "^4.0.1",
		"ts-node": "^10.9.2",
		"tsx": "4.21.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.29.1",
		"uuid": "^11.1.0"
	},
	"workspaces": [
		"webview-ui"
	],
	"dependencies": {
		"@modelcontextprotocol/sdk": "1.25.3",
		"@radix-ui/react-tooltip": "1.2.8",
		"@radix-ui/themes": "^3.2.1",
		"@vscode/codicons": "^0.0.38",
		"@vscode/l10n": "0.0.18",
		"chokidar": "4.0.3",
		"cross-env": "^10.0.0",
		"delay": "6.0.0",
		"dayjs": "1.11.19",
		"eventsource-parser": "^3.0.3",
		"express": "^5.1.0",
		"fast-glob": "^3.3.3",
		"got": "^14.4.7",
		"json-stream-stringify": "3.1.6",
		"jsonwebtoken": "^9.0.2",
		"jwt-decode": "^4.0.0",
		"micromatch": "4.0.8",
		"minimatch": "^10.0.3",
		"proper-lockfile": "4.1.2",
		"mock-fs": "5.5.0",
		"mock-require": "3.0.3",
		"react-markdown": "^10.1.0",
		"react-syntax-highlighter": "^15.6.6",
		"react-textarea-autosize": "^8.5.9",
		"reconnecting-eventsource": "1.6.4",
		"semver": "^7.7.2",
		"sparse-matrix": "1.0.0",
		"systeminformation": "5.31.1",
		"tree-sitter-wasms": "^0.1.12",
		"vitest": "4.0.18",
		"web-tree-sitter": "0.22.6"
	},
	"peerDependencies": {
		"cheerio": "1.0.0",
		"undici": "6.22.0"
	},
	"__metadata": {
		"installedTimestamp": 1776975493690,
		"targetPlatform": "undefined",
		"size": 38107288
	}
}